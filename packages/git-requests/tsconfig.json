{
  "compilerOptions": {
    "lib": [
      "esnext",
      "WebWorker"
    ],
    "checkJs": false,
    "module": "NodeNext",
    "target": "esnext",
    "types": [
      "jest"
    ],
    "moduleResolution": "NodeNext",
    "skipLibCheck": true,
    "emitDeclarationOnly": true,
    "isolatedModules": true,
    "assumeChangesOnlyAffectDirectDependencies": true,
    "strict": true,
    "rootDir": ".",
    "composite": true,
    "outDir": "dist",
    "allowImportingTsExtensions": true
  },
  "include": [
    "src",
    "test"
  ]
}
