{
  "name": "git-worker",
  "version": "0.0.0-dev",
  "description": "Worker process for the built-in Git integration.",
  "license": "MIT",
  "author": "Lvce Editor",
  "type": "module",
  "main": "src/gitWorkerMain.ts",
  "scripts": {
    "test": "node --unhandled-rejections=warn --experimental-vm-modules ../../node_modules/jest/bin/jest.js --detectOpenHandles --forceExit",
    "test:watch": "node --unhandled-rejections=warn --experimental-vm-modules ../../node_modules/jest/bin/jest.js --watch"
  },
  "jest": {
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    }
  },
  "devDependencies": {
    "@types/jest": "^30.0.0"
  }
}
